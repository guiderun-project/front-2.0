VITE_API_BASE_URL=https://api.guiderun.org/api
VITE_KAKAO_JAVASCRIPT_KEY=
# 카카오 콘솔의 REST API 키 (인가 코드 로그인용)
VITE_KAKAO_REST_API_KEY=
# 카카오 콘솔/백엔드에 등록된 Redirect URI 와 글자 단위로 동일해야 함
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/oauth
VITE_ENABLE_MSW=false
# MSW 부팅 시 인증 상태. 미설정/true=자동 로그인, false=비로그인(게스트)으로 시작
VITE_MOCK_AUTHENTICATED=true

VITE_POSTHOG_PROJECT_TOKEN=
VITE_POSTHOG_HOST=https://us.i.posthog.com
